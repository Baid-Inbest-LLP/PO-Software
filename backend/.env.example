# Optional: absolute path to the assets folder (logos, generated Admin_Stamp.png, etc.) when the
# server’s cwd or bundle layout does not match backend/assets (Docker, some serverless setups).
# PO_ASSETS_DIR=/app/assets

# Stamps: source JPEGs in assets/ are converted to PNG at `npm run generate:embedded-assets` (postinstall); no env overrides.
