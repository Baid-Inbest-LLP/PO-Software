{
  "name": "po-software",
  "version": "1.0.0",
  "private": true,
  "description": "Purchase Order Management System",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "build": "pnpm run --filter client build",
    "start": "pnpm --filter server start",
    "seed:dummy": "pnpm --filter server seed:dummy",
    "migrate:to-admin": "pnpm --filter server migrate:to-admin",
    "migrate:item-departments": "pnpm --filter server migrate:item-departments"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
